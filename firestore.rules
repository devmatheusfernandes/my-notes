rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Regras unificadas que determinam que o usuário só pode ler, criar, atualizar e excluir 
    // documentos (notas, pastas, etc) se estiver autenticado e for o dono dos dados.

    // Coleção de Notas
    match /notes/{noteId} {
      // Para ler/atualizar/deletar a nota precisa existir e pertencer ao uid logado
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      // Para criar, a nova nota precisa estar associada ao uid logado
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Coleção de Pastas
    match /folders/{folderId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Coleção de Configurações do Usuário
    match /userSettings/{userId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId && resource.data.userId == userId;
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.userId == userId;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && resource.data.userId == userId
                    && request.resource.data.userId == userId;
    }

  }
}

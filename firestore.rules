rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ----- FUNÇÕES AUXILIARES -----
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ----- REGRAS POR COLEÇÃO -----

    // Coleção de Notas
    match /notes/{noteId} {
      allow read, delete: if isOwner(resource.data.userId);
      
      allow create: if isOwner(request.resource.data.userId)
                    && request.resource.data.id == noteId
                    && isValidString(request.resource.data.title, 1, 20)
                    && request.resource.data.type in ['note', 'pdf']
                    && request.resource.data.archived is bool
                    && request.resource.data.trashed is bool
                    && request.resource.data.pinned is bool
                    && request.resource.data.isLocked is bool;

      allow update: if isOwner(resource.data.userId)
                    && isOwner(request.resource.data.userId)
                    && (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['title', 'content', 'searchText', 'tagIds', 'folderId', 'archived', 'trashed', 'pinned', 'updatedAt', 'fileUrl', 'isLocked']))
                    && (!request.resource.data.diff(resource.data).affectedKeys().contains('title') || isValidString(request.resource.data.title, 1, 20))
                    && (!request.resource.data.diff(resource.data).affectedKeys().contains('archived') || request.resource.data.archived is bool)
                    && (!request.resource.data.diff(resource.data).affectedKeys().contains('trashed') || request.resource.data.trashed is bool);
    }

    // Coleção de Pastas
    match /folders/{folderId} {
      allow read, delete: if isOwner(resource.data.userId);
      
      allow create: if isOwner(request.resource.data.userId)
                    && request.resource.data.id == folderId
                    && isValidString(request.resource.data.title, 1, 20)
                    && request.resource.data.archived is bool
                    && request.resource.data.trashed is bool;

      allow update: if isOwner(resource.data.userId)
                    && isOwner(request.resource.data.userId)
                    && (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['title', 'parentId', 'color', 'archived', 'trashed', 'updatedAt', 'isLocked']))
                    && (!request.resource.data.diff(resource.data).affectedKeys().contains('title') || isValidString(request.resource.data.title, 1, 20));
    }

    // Coleção de Tags
    match /tags/{tagId} {
      allow read, delete: if isOwner(resource.data.userId);
      
      allow create: if isOwner(request.resource.data.userId)
                    && request.resource.data.id == tagId
                    && isValidString(request.resource.data.title, 1, 15);

      allow update: if isOwner(resource.data.userId)
                    && isOwner(request.resource.data.userId)
                    && (request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['title', 'color', 'updatedAt']))
                    && (!request.resource.data.diff(resource.data).affectedKeys().contains('title') || isValidString(request.resource.data.title, 1, 15));
    }

    // Coleção de Configurações do Usuário
    match /userSettings/{userId} {
      allow read, delete: if isOwner(userId);
      
      allow create: if isOwner(userId)
                    && request.resource.data.userId == userId
                    && request.resource.data.autoBackupFrequency in ['daily', 'weekly', 'monthly']
                    && request.resource.data.biometricEnabled is bool;

      allow update: if isOwner(userId)
                    && request.resource.data.userId == userId
                    && (request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['pinSalt', 'pinHash', 'biometricEnabled', 'biometricCredentialId', 'autoBackupEnabled', 'autoBackupTime', 'autoBackupFrequency', 'lastBackupAt', 'driveRefreshToken', 'updatedAt']))
                    && (!request.resource.data.diff(resource.data).affectedKeys().contains('autoBackupFrequency') || request.resource.data.autoBackupFrequency in ['daily', 'weekly', 'monthly']);
    }

    // Coleção de Metadados de Mídia
    match /media/{mediaId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
                    && request.resource.data.id == mediaId;
      allow update: if isOwner(resource.data.userId)
                    && isOwner(request.resource.data.userId);
    }

    // Coleção de Uso de Quota (Armazenamento)
    match /usage/{userId} {
      allow read: if isOwner(userId);
      // Negar qualquer escrita direta do cliente. 
      // O sistema gerencia via firebase-admin no servidor.
      allow write: if false;
    }

    // Coleção de Créditos de IA
    match /credits/{userId} {
      allow read: if isOwner(userId);
      // Negar qualquer escrita direta do cliente.
      // O gerenciamento de recarga mensal e descontos é feito via servidor.
      allow write: if false;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

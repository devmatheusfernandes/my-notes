rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Padrão de segurança: permitir upload e leitura apenas no próprio diretório do usuário ({userId})
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Padrão de segurança: permitir upload e leitura apenas no próprio diretório do usuário
    match /users/{userId}/{allPaths=**} {
      
      // Apenas o dono autenticado pode ler seus arquivos
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Regra de Escrita (Create, Update, Delete)
      allow write: if request.auth != null && request.auth.uid == userId
                   && (
                     // Se for exclusão, permitir (request.resource é nulo no delete)
                     request.resource == null 
                     || 
                     // Se for upload/update, validar tamanho e cota total
                     (
                       request.resource.size <= 10 * 1024 * 1024 // Limite de 10MB por arquivo
                       &&
                       (
                         (firestore.get(/databases/(default)/documents/usage/$(userId)) == null 
                           ? 0 
                           : firestore.get(/databases/(default)/documents/usage/$(userId)).data.totalBytesUsed
                         ) + request.resource.size 
                       ) <= 200 * 1024 * 1024 // Cota máxima de 200MB
                     )
                   );
    }

    // Bloqueio padrão para qualquer outro caminho
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
